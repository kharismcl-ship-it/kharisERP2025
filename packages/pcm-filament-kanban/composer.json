{
    "name": "pcm/filament-kanban",
    "version": "1.0.0",
    "description": "Kanban boards for Filament v4+ — forked from mokhosh/filament-kanban and updated for Filament v4/v5 compatibility",
    "keywords": [
        "pcm",
        "laravel",
        "filament-kanban",
        "filament-v4"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "PCM (forked from Mo Khosh)",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.15.0",
        "illuminate/contracts": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Pcm\\FilamentKanban\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pcm\\FilamentKanban\\FilamentKanbanServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}